      ];
    }
    subgraph "cluster_export_module_Meta" {
      label = "Meta";
      style = "rounded";
      "export_module.serializers.task_serializer.Meta" [
        label = "Meta";
        color = "#D3D3D3";
        fillcolor = "#D3D3D3";
        shape = "ellipse";
        style = "filled";
        fontcolor = "#FFFFFF";
      ];
    }
    subgraph "cluster_export_module_TodoTaskViewSet" {
      label = "TodoTaskViewSet";
      style = "rounded";
      "export_module.views.todotask.TodoTaskViewSet" [
        label = "TodoTaskViewSet";
        color = "#4A90D9";
        fillcolor = "#4A90D9";
        shape = "box";
        style = "filled";
        fontcolor = "#FFFFFF";
      ];
      "export_module.views.todotask.TodoTaskViewSet.list" [
        label = "list";
        color = "#4A90D9";
        fillcolor = "#4A90D9";
        shape = "box";
        style = "filled";
        fontcolor = "#FFFFFF";
      ];
      "export_module.views.todotask.TodoTaskViewSet.export" [
        label = "export";
        color = "#4A90D9";
        fillcolor = "#4A90D9";
