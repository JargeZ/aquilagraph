{
  "name": "aquilagraph",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "workspaces": [
    "e2e"
  ],
  "scripts": {
    "sync:wasm": "node scripts/sync-tree-sitter-wasm.mjs",
    "icons:generate": "node scripts/generate-icons-from-logo.mjs",
    "prepare": "node scripts/sync-tree-sitter-wasm.mjs",
    "dev:vite": "node scripts/sync-tree-sitter-wasm.mjs && vite --port 3000",
    "lingui:extract": "lingui extract --clean",
    "build:vite": "node scripts/sync-tree-sitter-wasm.mjs && lingui extract --clean && vite build",
    "build:vite:pwa": "node scripts/sync-tree-sitter-wasm.mjs && lingui extract --clean && vite build --mode pwa",
    "preview": "vite preview",
    "preview:e2e": "vite preview --port 4141 --strictPort --host 127.0.0.1",
    "e2e": "node scripts/run-e2e.mjs",
    "test": "vitest run",
    "tauri": "tauri",
    "format": "biome format",
    "lint": "biome check",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "fix": "biome check --write",
    "dev": "tauri dev",
    "build": "tauri build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@lingui/core": "^5.9.5",
    "@lingui/detect-locale": "^5.9.5",
    "@lingui/react": "^5.9.5",
    "@luciformresearch/codeparsers": "^0.3.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.9.13",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-router-devtools": "^1.166.7",
    "@tanstack/router-plugin": "^1.166.7",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@viz-js/viz": "^3.25.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.7.0",
    "path-browserify": "^1.0.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.1",
    "svg-pan-zoom": "^3.6.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "ts-graphviz": "^3.0.7",
    "tw-animate-css": "^1.4.0",
    "usehooks-ts": "^3.1.1",
    "uuid": "^13.0.0",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@lingui/babel-plugin-lingui-macro": "^5.9.5",
    "@lingui/cli": "^5.9.5",
    "@lingui/vite-plugin": "^5.9.5",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/react": "10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.4.0",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "start-server-and-test": "^2.1.3",
    "storybook": "^10.3.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "web-vitals": "^5.1.0"
  }
}
