{
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "compilerOptions": {
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "module": "ESNext",
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    /* Linting */
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@/*": ["./src/*"],
      "@ui/*": ["./src/ui/*"],
      "@internal/codeparsers-python-scope": [
        "./node_modules/@luciformresearch/codeparsers/dist/esm/scope-extraction/PythonScopeExtractionParser.js"
      ],
      "@internal/codeparsers-ts-scope": [
        "./node_modules/@luciformresearch/codeparsers/dist/esm/scope-extraction/ScopeExtractionParser.js"
      ],
      "@internal/codeparsers-wasm-loader": [
        "./node_modules/@luciformresearch/codeparsers/dist/esm/wasm/WasmLoader.js"
      ]
    }
  },
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
